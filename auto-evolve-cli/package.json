{
  "name": "auto-evolve",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "auto-evolve": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write src tests",
    "format:check": "oxfmt --check src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
